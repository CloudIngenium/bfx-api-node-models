{
  "name": "@cloudingenium/bfx-api-node-models",
  "version": "10.0.4",
  "description": "TypeScript models for the Bitfinex API — CloudIngenium modernized fork",
  "type": "module",
  "engines": {
    "node": ">=24.0.0"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "postbuild": "node scripts/check-dist.mjs",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test": "npm run build && echo 'No unit tests defined yet — see TODO in CLAUDE.md'",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/CloudIngenium/bfx-api-node-models.git"
  },
  "keywords": [
    "bitfinex",
    "bitcoin",
    "BTC",
    "typescript",
    "models"
  ],
  "author": "Bitfinex",
  "contributors": [
    "JC <jcbauza@users.noreply.github.com> (https://github.com/jcbauza)",
    "Jacob Plaster <jacob.plaster@bitfinex.com> (https://www.bitfinex.com)",
    "Ezequiel Wernicke <ezequiel.wernicke@bitfinex.com> (https://www.bitfinex.com)",
    "Cris Mihalache <cris.m@bitfinex.com> (https://www.bitfinex.com)",
    "Paolo Ardoino <paolo@bitfinex.com> (https://www.bitfinex.com)",
    "Vigan Abdurrahmani <vigan.abdurrahmani@bitfinex.com> (https://www.bitfinex.com)"
  ],
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/CloudIngenium/bfx-api-node-models/issues"
  },
  "homepage": "https://github.com/CloudIngenium/bfx-api-node-models#readme",
  "dependencies": {
    "bignumber.js": "^9.3.1",
    "crc-32": "^1.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.2",
    "eslint": "^9.0.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.0.0"
  },
  "publishConfig": {
    "@cloudingenium:registry": "https://npm.pkg.github.com"
  },
  "packageManager": "pnpm@10.15.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "@swc/core",
      "better-sqlite3"
    ]
  }
}
